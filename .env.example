# =============================================================================
# Backend (FastAPI) — coloque na raiz do repositório; `backend/main.py` usa load_dotenv()
# =============================================================================

# --- Meta / Facebook / Instagram (Graph API) ---
# Token de utilizador com permissões nas Páginas e ativos (anúncios, Instagram comercial).
# Use um ou outro nome (o código aceita os dois):
META_USER_ACCESS_TOKEN=
# META_ACCESS_TOKEN=

# Versão da Graph API (ex.: v21.0). Se vazio, o backend usa o default do código.
META_GRAPH_API_VERSION=v21.0

# App (necessário para fluxos OAuth / renovação de token no Meta; o dashboard em si
# pode funcionar só com o token acima se já estiver válido):
META_APP_ID=
META_APP_SECRET=

# Conta de anúncios Meta (formato act_XXXXXXXXX). Usada pelas rotas /meta/* (insights, contas).
META_AD_ACCOUNT_ID=

# Instagram Business — ID numérico do utilizador IG (não é o @). Opcional se o front
# escolher conta via seletor + ?ig_id= (veja GET /instagram/connected-accounts).
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- Cotação (usada no Python, ex. exchange_rate) ---
# Opcional; default 5.5 se não definir. O frontend pode ter o mesmo valor com prefixo NEXT_PUBLIC_.
NEXT_PUBLIC_FALLBACK_USD_BRL=5.5

# =============================================================================
# Frontend (Next.js) — ficheiro `frontend/.env.local` (não commitar segredos reais)
# =============================================================================

# URL do backend que o browser chama (CORS deve permitir a origem do Next).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Supabase (cliente no browser; chaves “anon / publishable” do projeto).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Mesma cotação USD→BRL usada na UI quando não há cotação em tempo real.
NEXT_PUBLIC_FALLBACK_USD_BRL=5.5

# Deploy (exemplo):
# NEXT_PUBLIC_API_URL=https://<seu-backend>
